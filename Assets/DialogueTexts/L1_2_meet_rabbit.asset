  dialoguePieces:
  - id: meet_rb_1
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u6B22\u8FCE\u60A8\uFF0C\u64C5\u957F\u53D1\u73B0\u7591\u70B9\u7684\u5927\u4FA6\u63A2\u7231\u4E3D\u4E1D\u5C0F\u59D0\uFF01"
    nextID: meet_rb_2
    options: []
    isLastPiece: 0
  - id: meet_rb_2
    speakerType: 1
    speakerName: "\u7231\u4E3D\u4E1D"
    image: {fileID: 21300000, guid: 3769222f6f6a8fa489528a3e85534301, type: 3}
    text: "\uFF08\u539F\u6765\u662F\u5154\u5B50\u5417\uFF1F\u96BE\u602A\u9700\u8981\u6211\u94BB\u5730\u6D1E\u2026\u2026\uFF09"
    nextID: meet_rb_3
    options: []
    isLastPiece: 0
  - id: meet_rb_3
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u5F88\u4E0D\u5E78\u2014\u2014\u60A8\u5E94\u5F53\u5DF2\u7ECF\u77E5\u9053\u4E86\u2014\u2014\u6211\u4EEC\u7684\u5973\u738B\u5931\u8E2A\u4E86\u3002\u548C\u5973\u738B\u5931\u8E2A\u4E00\u5E76\u53D1\u751F\u7684\uFF0C\u8FD8\u6709\u4E00\u7CFB\u5217\u7684\u5F02\u5E38\u3002"
    nextID: meet_rb_4
    options: []
    isLastPiece: 0
  - id: meet_rb_4
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u6240\u4EE5\u6211\u4EEC\u9700\u8981\u4E00\u4F4D\u5F3A\u5927\u7684\u4FA6\u63A2\uFF0C\u80FD\u591F\u52D8\u7834\u8FD9\u4E9B\u53EF\u7591\u7684\u5F02\u5E38\uFF0C\u5E2E\u52A9\u6211\u4EEC\u627E\u56DE\u5973\u738B\u3002"
    nextID: meet_rb_5
    options: []
    isLastPiece: 0
  - id: meet_rb_5
    speakerType: 1
    speakerName: "\u7231\u4E3D\u4E1D"
    image: {fileID: 21300000, guid: 3769222f6f6a8fa489528a3e85534301, type: 3}
    text: "\u6211\u5F88\u4E50\u610F\u6548\u52B3\uFF01\u4F46\u662F\uFF0C\u6211\u8BE5\u4ECE\u54EA\u91CC\u5F00\u59CB\u5462\uFF1F"
    nextID: meet_rb_6
    options: []
    isLastPiece: 0
  - id: meet_rb_6
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u7591\u70B9\u5C31\u5728\u6211\u4EEC\u8EAB\u8FB9\u3002\u6BD4\u5982\u524D\u9762\u7684\u65AD\u5D16\u2014\u2014\u8FD9\u91CC\u672C\u8BE5\u6709\u4E00\u5EA7\u6865\uFF0C\u4F46\u5B83\u4E0D\u89C1\u4E86\u3002\u4FA6\u63A2\u5C0F\u59D0\uFF0C\u5F53\u60A8\u53D1\u73B0\u4E86\u7EBF\u7D22\u4E2D\u7684\u7591\u70B9\uFF0C\u60A8\u901A\u5E38\u4F1A\u600E\u4E48\u505A\u5462\uFF1F"
    nextID: meet_rb_7
    options: []
    isLastPiece: 0
  - id: meet_rb_7
    speakerType: 1
    speakerName: "\u7231\u4E3D\u4E1D"
    image: {fileID: 21300000, guid: 3769222f6f6a8fa489528a3e85534301, type: 3}
    text: "\u5514\uFF0C\u5728\u6211\u7684\u7EBF\u7D22\u672C\u4E0A\u2026\u2026\u6211\u4F1A\u5728\u53EF\u7591\u7684\u5730\u65B9\u8D34\u4E0A\u4E00\u4E2A\u5C0F\u5706\u70B9\u3002"
    nextID: meet_rb_8
    options: []
    isLastPiece: 0
