  dialoguePieces:
  - id: statue_1
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u4E00\u5BF9\u6251\u514B\u724C\u536B\u5175\u7684\u96D5\u50CF\u3002\u770B\u5230\u5B83\u4EEC\u65F6\uFF0C\u4F60\u60F3\u8D77\u4E86\u66FE\u7ECF\u542C\u5230\u7684\u53EA\u8A00\u7247\u8BED\u2026\u2026"
    nextID: statue_2
