    isLastPiece: 0
  - id: statue_2
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u65E2\u7136\u4F60\u662F\u5973\u738B\uFF0C\u4F60\u5C31\u5F97\u6709\u4E00\u652F\u519B\u961F\u624D\u884C\u5440\u3002\u201D\n\u201C\u8BA9\u6211\u60F3\u60F3\u3002\u4F60\u9700\u8981\u6709\u5F88\u591A\u5F88\u591A\u7684\u519B\u961F\u2026\u2026\u5C31\u50CF\u6C99\u5B50\u90A3\u4E48\u591A\uFF1F\u4E0D\u884C\uFF0C\u6C99\u5B50\u592A\u5C0F\u4E86\uFF0C\u654C\u4EBA\u4E00\u811A\u5C31\u8E29\u6B7B\u4E86\u3002\u201D"
    nextID: statue_3
    options: []
    isLastPiece: 0
  - id: statue_3
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u6211\u77E5\u9053\u4E86\uFF0C\u4F60\u8981\u6709\u4E00\u652F\u6251\u514B\u724C\u519B\u961F\uFF01\u4E00\u76D2\u6251\u514B\u724C\u5C31\u6709\u90A3\u4E48\u591A\u5F20\uFF0C\u800C\u4F60\u6709\u4E00\u62BD\u5C49\u2014\u2014\u4E0D\uFF0C\u4E00\u6574\u4E2A\u623F\u95F4\u7684\u6251\u514B\u724C\uFF01\u5B83\u4EEC\u5168\u662F\u4F60\u7684\u58EB\u5175\uFF01\u201D"
    nextID: statue_4
