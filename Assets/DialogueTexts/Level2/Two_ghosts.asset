    isLastPiece: 0
  - id: talkers-2
    speakerType: 1
    speakerName: "\u5E73\u9759\u7684\u5C0F\u5E7D\u7075"
    image: {fileID: 0}
    text: "\u745E\u6587\u5C14\uFF0C\u4F60\u600E\u4E48\u4E5F\u5728\u8FD9\u91CC\uFF1F\u96BE\u9053\u4F60\u4E5F\u88AB\u2026\u2026"
    nextID: talkers-3
    options: []
    isLastPiece: 0
  - id: talkers-3
    speakerType: 0
    speakerName: "\u4F24\u5FC3\u7684\u5C0F\u5E7D\u7075"
    image: {fileID: 0}
    text: "\u53EA\u662F\u56E0\u4E3A\u4E00\u4E9B\u5C0F\u4E8B\u2026\u2026\u4E0D\u8FC7\u8C01\u4E0D\u662F\u5462\u3002"
    nextID: talkers-4
    options: []
    isLastPiece: 0
  - id: talkers-4
    speakerType: 1
    speakerName: "\u5E73\u9759\u7684\u5C0F\u5E7D\u7075"
    image: {fileID: 0}
    text: "\u6CA1\u4E8B\u7684\u745E\u6587\u5C14\uFF0C\u6211\u6CA1\u6709\u602A\u7F6A\u8FC7\u4F60\u3002\u660E\u660E\u4E0D\u4E45\u4E4B\u524D\uFF0C\u5973\u738B\u2014\u2014\u8FD8\u6709\u90A3\u4E2A\u4EBA\u2014\u2014\u548C\u6211\u4EEC\u8FD8\u662F\u670B\u53CB\u3002\u8C01\u80FD\u6599\u60F3\u5230\u4E8B\u60C5\u4F1A\u53D8\u6210\u8FD9\u6837\u5462\u3002"
    nextID: talkers-5
    options: []
    isLastPiece: 0
  - id: talkers-5
    speakerType: 0
    speakerName: "\u4F24\u5FC3\u7684\u5C0F\u5E7D\u7075"
    image: {fileID: 0}
    text: "\u90A3\u4E2A\u4EBA\uFF0C\u5979\u4E3A\u4EC0\u4E48\u8981\u8FD9\u4E48\u505A\u2026\u2026\u5979\u628A\u5973\u738B\u53D8\u6210\u4E86\u90A3\u4E2A\u6837\u5B50\u2026\u2026"
