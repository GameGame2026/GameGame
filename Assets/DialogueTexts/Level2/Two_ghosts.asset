  dialoguePieces:
  - id: talkers-1
    speakerType: 0
    speakerName: "\u4F24\u5FC3\u7684\u5C0F\u5E7D\u7075"
    image: {fileID: 0}
    text: "\u8389\u739B\uFF0C\u8389\u739B\uFF01\u5BF9\u4E0D\u8D77\uFF01\uFF01\u5982\u679C\u65E9\u77E5\u9053\u4F1A\u8FD9\u6837\uFF0C\u6211\u5F53\u65F6\u7EDD\u5BF9\u4E0D\u4F1A\u558A\u4F60\u7684\u540D\u5B57\u2026\u2026\u6211\u4EE5\u4E3A\u53EA\u662F\u95F9\u7740\u73A9\u2026\u2026"
