  m_Name: L3_Diary_1
  m_EditorClassIdentifier: 
  dialoguePieces:
  - id: diary1_1
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u8FD9\u4F3C\u4E4E\u662F\u4ECE\u8C01\u7684\u65E5\u8BB0\u672C\u4E0A\u6495\u4E0B\u6765\u7684\u4E00\u9875\u3002\u4E0A\u9762\u94A2\u7B14\u5B57\u8FF9\u6E05\u6670\u6574\u6D01\uFF0C\u7136\u800C\u7EB8\u5F20\u672C\u8EAB\u5374\u7834\u7834\u70C2\u70C2\uFF0C\u597D\u50CF\u662F\u88AB\u80E1\u4E71\u5730\u6495\u626F\u4E0B\u6765\u7684\u3002"
    nextID: diary1_2
    options: []
    isLastPiece: 0
  - id: diary1_2
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u2026\u2026\u7136\u800C\u5373\u4F7F\u662F\u795E\u660E\uFF0C\u4E5F\u6709\u53EF\u80FD\u5931\u53BB\u5176\u529B\u91CF\u3002\u6B63\u5982\u5C11\u6709\u4EBA\u80FD\u5728\u68A6\u5883\u91CC\u8086\u610F\u5984\u4E3A\uFF0C\u88AB\u5669\u68A6\u60CA\u5413\u7684\u4EBA\u5374\u4E0D\u5728\u5C11\u6570\u3002\u521B\u4E16\u8005\u5BF9\u4E16\u754C\u7684\u5F71\u54CD\u80FD\u529B\uFF0C\u5F88\u5927\u7A0B\u5EA6\u4E0A\u53D6\u51B3\u4E8E\u5176\u5BF9\u81EA\u5DF1\u80FD\u529B\u7684<b>\u76F8\u4FE1</b>\u7A0B\u5EA6\u3002\u201D"
    nextID: diary1_3
    options: []
    isLastPiece: 0
  - id: diary1_3
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u4E24\u4E2A\u4E16\u754C\u7684\u65F6\u95F4\u6D41\u901F\u4E0D\u540C\uFF0C\u5B8C\u5168\u65E0\u6CD5\u9884\u6599\u5979\u6B64\u523B\u7684\u5E74\u9F84\u3002\u800C\u5E74\u9F84\u6070\u597D\u662F\u884C\u4F7F\u529B\u91CF\u7684\u4E00\u5927\u963B\u788D\uFF0C\u56E0\u4E3A\u5B83\u5E26\u6765\u66F4\u5177\u6761\u7406\u7684\u8BA4\u77E5\u80FD\u529B\uFF0C\u5374\u4E5F\u9650\u5236\u4E86\u5BF9\u79CD\u79CD\u8131\u79BB\u5E38\u7406\u4E4B\u4E8B\u7684\u7406\u89E3\u548C\u63A5\u53D7\u80FD\u529B\u3002\u201D"
    nextID: diary1_4
    options: []
    isLastPiece: 0
  - id: diary1_4
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u4E0D\u8FC7\u65E0\u8BBA\u5982\u4F55\uFF0C\u8FD8\u662F\u5F97\u5148\u627E\u5230<b>\u5979</b>\u624D\u884C\u2026\u2026\u627E\u5230\u5979\uFF0C\u624D\u80FD\u5224\u65AD\u5979\u7684\u72B6\u51B5\u662F\u5426\u8DB3\u4EE5\u914D\u5408\u6211\u7684\u8BA1\u5212\u3002\u201D"
    nextID: diary1_5
    options: []
    isLastPiece: 0
  - id: diary1_5
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u4E0B\u9762\u662F\u53E6\u5916\u4E00\u79CD\u7EA2\u58A8\u6C34\u4E66\u5199\u7684\u3001\u6B6A\u6B6A\u626D\u626D\u7684\u5B57\u8FF9\uFF1A\u201C\u53BB\u4F60\u7684\uFF0C\u8BA8\u538C\u7684\u5BB6\u4F19\uFF01\u201D"
    nextID: 
    options: []
    isLastPiece: 1
