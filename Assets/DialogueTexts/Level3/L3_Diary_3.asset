  m_Name: L3_Diary_3
  m_EditorClassIdentifier: 
  dialoguePieces:
  - id: diary3_1
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u627E\u5230<b>\u5979</b>\u4E86\u3002\u5979\u73B0\u5728\u770B\u8D77\u6765\u5341\u4E03\u516B\u5C81\uFF0C\u5728\u7ECF\u8425\u4E00\u5BB6\u4FA6\u63A2\u4E8B\u52A1\u6240\u3002\u5728\u6211\u4EEC\u7684\u4E16\u754C\u7684\u7ECF\u5386\u4F3C\u4E4E\u6CA1\u6709\u5BF9\u5979\u9020\u6210\u4EFB\u4F55\u5F71\u54CD\u2026\u2026\u4E5F\u662F\uFF0C\u5927\u591A\u6570\u68A6\u5883\uFF0C\u5728\u9192\u6765\u4E4B\u65F6\u5C31\u4F1A\u88AB\u5FD8\u6389\u5927\u534A\u5427\u3002\u201D"
    nextID: diary3_2
    options: []
    isLastPiece: 0
  - id: diary3_2
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u5F88\u96BE\u8BF4\u5979\u7684\u80FD\u529B\u9000\u5316\u5230\u4E86\u4F55\u79CD\u7A0B\u5EA6\u3002\u4E0D\u8FC7\u597D\u7684\u4E00\u9762\u662F\uFF0C\u4E8B\u60C5\u4E5F\u8BB8\u4F1A\u53D8\u5F97\u66F4\u53EF\u63A7\uFF0C\u6211\u66F4\u6709\u53EF\u80FD\u5C06\u5979\u5F15\u5BFC\u5411\u6211\u5E0C\u671B\u7684\u7ED3\u679C\u3002\u4E0D\u8FC7\u9996\u8981\u7684\u96BE\u9898\u8FD8\u662F\uFF0C\u600E\u6837\u8BA9\u5979\u4ECD\u7136\u80FD\u591F\u4F7F\u7528\u51FA\u5979\u7684\u529B\u91CF\uFF1F\u201D"
    nextID: diary3_3
    options: []
    isLastPiece: 0
  - id: diary3_3
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u2026\u2026\u4EBA\u4EEC\u5F80\u5F80\u96BE\u4EE5\u60F3\u8C61\u62BD\u8C61\u7684\u4E8B\u60C5\uFF0C\u5374\u66F4\u5BB9\u6613\u76F8\u4FE1\u5177\u4F53\u7684\u4E8B\u60C5\u3002\u6BD4\u8D77\u2018\u4EFB\u610F\u5730\u5F71\u54CD\u4E16\u754C\u2019\uFF0C\u2018\u7279\u5B9A\u884C\u4E3A\u80FD\u4EE5\u7279\u5B9A\u65B9\u5F0F\u6539\u53D8\u4E16\u754C\u2019\u4F1A\u5BB9\u6613\u63A5\u53D7\u5F97\u591A\u3002\u201C"
    nextID: diary3_4
    options: []
    isLastPiece: 0
  - id: diary3_4
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u8BA9\u6211\u770B\u770B\u2026\u2026\u5979\u662F\u4E2A\u4FA6\u63A2\uFF0C\u5979\u4F1A\u5728\u53EF\u7591\u7684\u8BB0\u5F55\u4E0A\u8D34\u70B9\u3002\u554A\uFF0C\u6709\u4E86\uFF01\u201D"
    nextID: diary3_5
    options: []
    isLastPiece: 1
  - id: diary3_5
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u300C\u8D34\u70B9\u5C31\u80FD\u4FEE\u6B63\u53EF\u7591\u7684\u4E1C\u897F\u300D\u2014\u2014\u8FD9\u8DB3\u4EE5\u7528\u6210\u5E74\u4EBA\u7684\u8BA4\u77E5\u91CD\u5851\u4E00\u904D\u8FD9\u4E2A\u4E16\u754C\u4E86\uFF0C\u4E5F\u80FD\u62B9\u53BB\u76F8\u5F53\u4E00\u90E8\u5206\u5973\u738B\u7559\u4E0B\u7684\u75D5\u8FF9\u3002\u6BD5\u7ADF\u602A\u5F02\u7684\u3001\u65E0\u903B\u8F91\u7684\u751F\u6D3B\uFF0C\u6B63\u662F\u5973\u738B\u7684\u7EDF\u6CBB\u7684\u7279\u70B9\u4E4B\u4E00\u3002\u201D"
    nextID: diary3_6
    options: []
    isLastPiece: 0
  - id: diary3_6
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u5F88\u597D\uFF0C\u73B0\u5728\u53EA\u9700\u8981\u8003\u8651\u600E\u4E48\u628A<b>\u5979</b>\u518D\u6B21\u5E26\u8FDB\u8FD9\u4E2A\u4E16\u754C\u91CC\u2026\u2026\u201D"
    nextID: 
    options: []
    isLastPiece: 1
