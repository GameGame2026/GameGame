    text: "\u65E9\u4E0A\u597D\uFF0C\u7231\u4E3D\u4E1D\u5C0F\u59D0\u3002\u5973\u738B\u5728\u6D88\u5931\u524D\u4F3C\u4E4E\u5149\u987E\u8FC7\u8FD9\u7247\u68EE\u6797\uFF0C\u4ECA\u5929\u8BF7\u5148\u5728\u8FD9\u91CC\u627E\u627E\u7EBF\u7D22\u5427\u3002"
