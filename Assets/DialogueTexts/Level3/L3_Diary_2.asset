  m_Name: L3_Diary_2
  m_EditorClassIdentifier: 
  dialoguePieces:
  - id: diary2_1
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u6211\u5B9E\u5728\u662F\u4E0D\u660E\u767D\u3002\u90A3\u4E9B\u8FC2\u8150\u7684\u6251\u514B\u58EB\u5175\u2026\u2026\u4ED6\u4EEC\u5DF2\u7ECF\u8FD9\u4E48\u4E45\u6CA1\u6709\u89C1\u5230\u5973\u738B\u4E86\uFF0C\u4E3A\u4EC0\u4E48\u8FD8\u662F\u4E0D\u80AF\u627F\u8BA4\u53E6\u7ACB\u65B0\u738B\u7684\u5FC5\u8981\u6027\u5462\uFF01\u4ED6\u4EEC\u73B0\u5728\u6548\u5FE0\u7684\u5230\u5E95\u662F\u8C01\uFF1F\u4E00\u5957\u5236\u5EA6\u5417\uFF1F\u8FD8\u662F\u4E00\u4E2A\u9B3C\u9B42\uFF1F\u201D"
    nextID: diary2_2
    options: []
    isLastPiece: 0
  - id: diary2_2
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u800C\u4E14\u8BF4\u767D\u4E86\uFF0C\u5E74\u8F7B\u7684\u5973\u738B\u5236\u5B9A\u7684\u90A3\u4E9B\u4E71\u4E03\u516B\u7CDF\u7684\u89C4\u5219\uFF0C\u6839\u672C\u4E0D\u80FD\u79F0\u4E4B\u4E3A\u5236\u5EA6\u3002\u201D"
    nextID: diary2_3
    options: []
    isLastPiece: 0
  - id: diary2_3
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u4E0D\uFF0C\u51B7\u9759\u4E0B\u6765\u3002\u5373\u4F7F\u73B0\u72B6\u5982\u6B64\u8352\u8BDE\uFF0C\u4E5F\u5E94\u5F53\u5C06\u5176\u89C6\u4F5C\u4E00\u4E2A\u5BA2\u89C2\u7684\u73B0\u8C61\uFF1A\u4EBA\u4EEC\u4ECD\u7136\u50CF\u5973\u738B\u5C1A\u5728\u65F6\u4E00\u6837\u5DE5\u4F5C\u548C\u751F\u6D3B\uFF0C\u5373\u4F7F\u4ED6\u4EEC\u77E5\u9053\u5973\u738B\u5DF2\u7ECF\u6D88\u5931\u2014\u2014\u6216\u8005\u6309\u4ED6\u4EEC\u90A3\u53EF\u601C\u7684\u8BF4\u6CD5\u2014\u2014\u2018\u6682\u65F6\u5931\u8E2A\u2019\u3002\u201D"
    nextID: diary2_4
    options: []
    isLastPiece: 0
  - id: diary2_4
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u5982\u679C\u4EBA\u4EBA\u90FD\u662F\u8FD9\u6837\uFF0C\u8FD9\u6050\u6015\u8BF4\u660E\u5973\u738B\u4E0E<b>\u5979</b>\u7684\u6700\u540E\u4E00\u6218\u5BF9\u8FD9\u4E2A\u4E16\u754C\u9020\u6210\u4E86\u67D0\u79CD\u5B9E\u8D28\u6027\u7684\u5F71\u54CD\u3002\u8BB0\u5FC6\uFF0C\u4E60\u60EF\uFF0C\u601D\u7EF4\u5B9A\u52BF\u2026\u2026\u65E0\u8BBA\u90A3\u662F\u4EC0\u4E48\uFF0C\u8FD9\u79CD\u5F71\u54CD\u90FD\u5BA2\u89C2\u5B58\u5728\u7740\uFF0C\u963B\u788D\u7740\u540E\u6765\u8005\u505A\u51FA\u6539\u53D8\u3002\u201D"
    nextID: diary2_5
    options: []
    isLastPiece: 0
  - id: diary2_5
    speakerType: 2
    speakerName: 
    image: {fileID: 0}
    text: "\u201C\u5973\u738B\u88AB<b>\u5979</b>\u8D4B\u4E88\u8FC7\u989D\u5916\u7684\u80FD\u529B\uFF0C\u5018\u82E5\u91CA\u653E\u5168\u529B\uFF0C\u5927\u6982\u786E\u5B9E\u80FD\u5728\u4E16\u754C\u4E0A\u7559\u4E0B\u8FD9\u6837\u7684\u75D5\u8FF9\u2026\u2026\u53EF\u6076\uFF0C\u660E\u660E\u6211\u624D\u662F\u6700\u521D\u7684\u9020\u7269\uFF0C\u4E3A\u4EC0\u4E48\u8FD9\u79CD\u529B\u91CF\u6CA1\u6709\u8D4B\u4E88\u6211\uFF01\u201D"
    nextID: 
    options: []
    isLastPiece: 1
