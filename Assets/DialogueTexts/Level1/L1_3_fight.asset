    options: []
    isLastPiece: 0
  - id: fight_1
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u5BF9\u4E86\uFF0C\u60A8\u4E5F\u8BB8\u5DF2\u7ECF\u770B\u5230\u4E86\u2014\u2014\u60A8\u7684\u8C03\u67E5\u8DEF\u4E0A\u514D\u4E0D\u4E86\u6709\u4E9B\u60F3\u8981\u963B\u6321\u60A8\u7684\u654C\u4EBA\u3002"
    nextID: fight_2
    options: []
    isLastPiece: 0
  - id: fight_2
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u6211\u53EA\u662F\u4E00\u53EA\u5F31\u5C0F\u7684\u5154\u5B50\uFF0C\u5E2E\u4E0D\u4E0A\u4EC0\u4E48\u5FD9\u3002\u4E0D\u8FC7\uFF0C\u60A8\u4E00\u5B9A\u80FD\u7528\u60A8\u9AD8\u8D35\u7684\u624B\u6756\u72E0\u72E0\u5730\u6572\u6253\u5B83\u4EEC\u4E00\u987F\uFF01\uFF08\u6309'/'\u952E\uFF0C\u6325\u821E\u624B\u6756\u653B\u51FB\u654C\u4EBA\uFF01\uFF09"
    nextID: fight_3
    options: []
    isLastPiece: 0
  - id: fight_3
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u60A8\u4E5F\u53EF\u4EE5\u5BF9\u654C\u4EBA<b>\u8D34\u70B9</b>\u3002\u8FD9\u901A\u5E38\u80FD\u8BA9\u8FD9\u4E9B\u56A3\u5F20\u7684\u5BB6\u4F19\u4EEC\u6536\u655B\u5F97\u591A\u3002"
