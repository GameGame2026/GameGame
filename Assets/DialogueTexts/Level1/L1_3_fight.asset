    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u5E72\u5F97\u6F02\u4EAE\uFF0C\u4FA6\u63A2\u5C0F\u59D0\uFF01\u60A8\u5DF2\u7ECF\u638C\u63E1\u4E86\u5728\u8FD9\u4E2A\u53E4\u602A\u4E16\u754C\u91CC\u63A2\u7D22\u7684\u57FA\u672C\u65B9\u6CD5\u3002\u8BF7\u5927\u80C6\u5730\u5C1D\u8BD5\u5BF9\u53EF\u7591\u7684\u4E1C\u897F\u8D34\u70B9\u5427\u3002"
