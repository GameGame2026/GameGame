  - id: after_fight_4
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u554A\uFF01\u4FA6\u63A2\u5C0F\u59D0\uFF0C\u60A8\u5728\u8FD9\u91CC\uFF01"
    nextID: after_fight_5
    options: []
