    speakerName: "\u67F4\u90E1\u732B"
    image: {fileID: -1240867006, guid: 4b488b92ad047b14b80652c225315fdb, type: 3}
    text: "\u5BF9\u4E0D\u8D77\u2026\u2026\u6211\u7684\u965B\u4E0B\u2026\u2026"
