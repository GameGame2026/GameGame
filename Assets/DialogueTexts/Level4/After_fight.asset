  - id: after_fight_5
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u8FD9\u662F\uFF0C\u4E00\u53EA\u4F1A\u4F24\u4EBA\u7684\u3001\u54A7\u5634\u7B11\u7684\u732B\uFF1F\u4FA6\u63A2\u5C0F\u59D0\uFF0C\u6211\u60F3\u8FD9\u4E5F\u662F\u4E00\u4E2A\u5F88<b>\u53EF\u7591</b>\u7684\u52A8\u7269\uFF0C\u60A8\u4E0D\u89C9\u5F97\u5417\uFF1F"
    nextID: after_fight_6
    options: []
    isLastPiece: 0
  - id: after_fight_6
    speakerType: 0
    speakerName: "\u767D\u5154"
    image: {fileID: 21300000, guid: be3e0a95e30e14546a9e2f269bca7e02, type: 3}
    text: "\u5982\u679C\u521A\u624D\u60A8\u65E0\u6CD5\u7ED9\u5B83\u8D34\u4E0A\u70B9\u7684\u8BDD\uFF0C\u6211\u60F3<b>\u73B0\u5728</b>\u53EF\u4EE5\u4E86\u3002"
